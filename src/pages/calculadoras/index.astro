---
// calculadoras/index — landing das calculadoras.
// OUTLIER: única página do site com o chrome "sidebar/dashboard" (todas as
// outras usam o topbar). Portada 1:1 COM o sidebar, de propósito — unificar no
// chrome topbar seria redesign → registrado no FUTURE.md, feito depois.
// Por isso NÃO usa o Layout.astro (topbar); é um documento standalone.
//
// CSS importado aqui é bundlado + hasheado pelo Vite e injetado no <head>.
import '../../styles/theme.css';
import '../../styles/theme-dark.css';
import '../../styles/sidebar.css';
import '../../styles/sidebar-sobre.css';
import '../../styles/dashboard.css';
import '../../styles/dashboard-wide.css';
import '../../styles/polish.css';
---
<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Calculadoras · Invest Analysis</title>
<style is:global>
  .calc-launcher-hero {
    text-align: center;
    max-width: 600px;
    margin: 24px auto 36px;
    padding: 0 16px;
  }
  .calc-launcher-hero h1 {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 38px;
    line-height: 1.05;
    font-weight: 600;
    color: var(--text);
    margin: 12px 0 14px;
    letter-spacing: -0.8px;
  }
  .calc-launcher-hero p {
    font-size: 14px;
    color: var(--muted);
    line-height: 1.55;
    max-width: 480px;
    margin: 0 auto;
  }
  .calc-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 14px;
    max-width: 760px;
    margin: 0 auto;
  }
  .calc-card {
    background: var(--surface);
    border-radius: var(--radius-lg);
    padding: 22px 20px 18px;
    box-shadow: var(--shadow-md);
    border: 1px solid var(--border);
    cursor: pointer;
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
    transition: transform .2s ease, box-shadow .2s ease;
    min-height: 180px;
  }
  .calc-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-lg);
  }
  .calc-card-icon {
    width: 40px;
    height: 40px;
    border-radius: 11px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 14px;
    background: var(--info-bg);
    color: var(--info);
  }
  .calc-card-icon svg { width: 18px; height: 18px; }
  .calc-card h3 {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 18px;
    font-weight: 600;
    margin: 0 0 6px;
    letter-spacing: -0.2px;
    color: var(--text);
  }
  .calc-card p {
    font-size: 12px;
    color: var(--muted);
    line-height: 1.5;
    margin: 0 0 14px;
    flex: 1;
  }
  .calc-card-footer {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    border-top: 1px solid var(--divider);
    padding-top: 12px;
    color: var(--info);
  }
  .calc-card-footer svg { transition: transform .2s ease; }
  .calc-card:hover .calc-card-footer svg { transform: translateX(3px); }

  @media (max-width: 700px) {
    .calc-grid { grid-template-columns: 1fr; }
    .calc-launcher-hero h1 { font-size: 30px; }
  }
</style>
<!-- Cloudflare Web Analytics -->
<script is:inline defer src="https://static.cloudflareinsights.com/beacon.min.js" data-cf-beacon='{"token": "a12338ede7f9426e80e3969dc9188753"}'></script>
<!-- End Cloudflare Web Analytics -->
</head>
<body>
<script is:inline>(function(){try{var t=localStorage.getItem("site-theme");if(t!=="light")document.body.classList.add("theme-dark");}catch(e){}})();</script>

<div data-ticker class="atb-ticker"></div>

<button class="hamburger" aria-label="Abrir menu">
  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round">
    <line x1="3" y1="6" x2="21" y2="6"/>
    <line x1="3" y1="12" x2="21" y2="12"/>
    <line x1="3" y1="18" x2="21" y2="18"/>
  </svg>
</button>
<div class="sidebar-backdrop"></div>

<div class="app-shell">

<aside class="sidebar">
  <a href="/index.html" class="sb-brand">
    <div class="sb-logo">i</div>
    <div class="sb-brand-text">Ferramentas<br>Especialistas</div>
  </a>

  <div class="sb-section-label">Investimentos</div>
  <nav class="sb-nav">
    <a href="/index.html" data-page="index.html" class="sb-link area-home">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/>
        <rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/>
      </svg>
      Início
    </a>
    <a href="/fundos.html" data-page="fundos.html" class="sb-link area-fundos">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M3 3v18h18"/><path d="M7 14l4-4 4 4 6-6"/>
      </svg>
      Fundos 555
    </a>
    <a href="/previdencia.html" data-page="previdencia.html" class="sb-link area-prev">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M12 2v20"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>
      </svg>
      Previdência
    </a>
    <a href="/comparacao.html" data-page="comparacao.html" class="sb-link area-comp">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M3 3v18h18"/>
        <path d="M7 15l4-4 3 3 4-6"/>
        <path d="M7 18l4-1 3 2 4-3"/>
      </svg>
      Comparar Fundos
    </a>
    <a href="/correlacao.html" data-page="correlacao.html" class="sb-link area-corr">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="9"/><path d="M3 12h18"/>
        <path d="M12 3a13 13 0 0 1 0 18"/><path d="M12 3a13 13 0 0 0 0 18"/>
      </svg>
      Correlação
    </a>
    <a href="/calculadoras.html" data-page="calculadoras" class="sb-link area-calc">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <rect x="4" y="3" width="16" height="18" rx="2"/>
        <line x1="8" y1="7" x2="16" y2="7"/><line x1="8" y1="11" x2="10" y2="11"/>
        <line x1="13" y1="11" x2="16" y2="11"/><line x1="8" y1="15" x2="10" y2="15"/>
        <line x1="13" y1="15" x2="16" y2="15"/>
      </svg>
      Calculadoras
    </a>
  </nav>

  <div class="sb-section-label sb-section-label--divider">Plan. Financeiro</div>
  <nav class="sb-nav">
    <a href="/calculadoras/simular-pgbl.html" data-page="simular-pgbl.html" class="sb-link area-pgbl">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="10"/>
        <circle cx="12" cy="12" r="6"/>
        <circle cx="12" cy="12" r="2"/>
      </svg>
      Simular PGBL
    </a>
    <a href="/calculadoras/aposentadoria.html" data-page="aposentadoria.html" class="sb-link area-apos">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M12 2v4"/>
        <path d="M12 22v-4"/>
        <path d="M4.93 4.93l2.83 2.83"/>
        <path d="M16.24 16.24l2.83 2.83"/>
        <path d="M2 12h4"/>
        <path d="M18 12h4"/>
        <circle cx="12" cy="12" r="4"/>
      </svg>
      Aposentadoria
    </a>
    <a href="/calculadoras/irpfm.html" data-page="irpfm.html" class="sb-link area-irpfm">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <rect x="4" y="3" width="16" height="18" rx="2"/>
        <line x1="8"  y1="8"  x2="16" y2="8"/>
        <line x1="8"  y1="12" x2="16" y2="12"/>
        <line x1="8"  y1="16" x2="12" y2="16"/>
      </svg>
      IRPFm 2026
    </a>
    <a href="/calculadoras/come-cotas.html" data-page="come-cotas.html" class="sb-link area-comecotas">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M12 3v18"/><path d="M7 7h7a3 3 0 0 1 0 6H8"/><path d="M7 17h8"/>
      </svg>
      Come-cotas
    </a>
    <a href="/calculadoras/valor-futuro.html" data-page="valor-futuro.html" class="sb-link area-valorfuturo">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M3 17l6-6 4 4 8-8"/><path d="M15 7h6v6"/>
      </svg>
      Valor Futuro
    </a>
  </nav>

  <div class="sb-section-label sb-section-label-perfil">Perfil</div>
  <nav class="sb-nav">
    <a href="/sobre.html" data-page="sobre.html" class="sb-link area-sobre">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="7" r="4"/>
        <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
      </svg>
      Sobre
    </a>
  </nav>

  <div class="sb-footer">
    <div class="sb-footer-label">Atualizado</div>
    <div class="sb-footer-value">16/05/2026</div>
  </div>
</aside>


  <main class="main">

    <section class="calc-launcher-hero">
      <div class="eyebrow">Ferramentas de simulação</div>
      <h1>Calculadoras</h1>
      <p>Simule decisões de troca de ativos, limites do FGC, rentabilidade real e crédito vs investimentos.</p>
    </section>

    <div class="calc-grid">

      <a href="/calculadoras/troca-ativos.html" class="calc-card">
        <div class="calc-card-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="17 1 21 5 17 9"/>
            <path d="M3 11V9a4 4 0 0 1 4-4h14"/>
            <polyline points="7 23 3 19 7 15"/>
            <path d="M21 13v2a4 4 0 0 1-4 4H3"/>
          </svg>
        </div>
        <h3>Troca de Ativos</h3>
        <p>Compare valor no vencimento e descubra a taxa de break even ao trocar um papel por outro.</p>
        <div class="calc-card-footer">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
          </svg>
        </div>
      </a>

      <a href="/calculadoras/limite-fgc.html" class="calc-card">
        <div class="calc-card-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
          </svg>
        </div>
        <h3>Limite FGC</h3>
        <p>Calcule quanto investir hoje para atingir exatamente R$ 250 mil no vencimento.</p>
        <div class="calc-card-footer">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
          </svg>
        </div>
      </a>

      <a href="/calculadoras/alocacao-fgc.html" class="calc-card">
        <div class="calc-card-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="4" width="18" height="16" rx="2"/>
            <line x1="3" y1="9" x2="21" y2="9"/>
            <line x1="9" y1="9" x2="9" y2="20"/>
            <line x1="15" y1="9" x2="15" y2="20"/>
          </svg>
        </div>
        <h3>Alocação FGC</h3>
        <p>Monte a tabela de sugestão multi-ativos com bruto, IR, líquido e ROI projetados no vencimento.</p>
        <div class="calc-card-footer">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
          </svg>
        </div>
      </a>

      <a href="/calculadoras/rentabilidade.html" class="calc-card">
        <div class="calc-card-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M3 3v18h18"/>
            <path d="M7 14l4-4 4 4 6-6"/>
          </svg>
        </div>
        <h3>Rentabilidade</h3>
        <p>Avalie rentabilidade bruta, líquida, % CDI e ágio/deságio em curva ou marcação a mercado.</p>
        <div class="calc-card-footer">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
          </svg>
        </div>
      </a>

      <a href="/calculadoras/credito-vs-invest.html" class="calc-card">
        <div class="calc-card-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="2" y="6" width="20" height="14" rx="2"/>
            <line x1="2" y1="10" x2="22" y2="10"/>
            <line x1="6" y1="15" x2="6" y2="15"/>
            <line x1="10" y1="15" x2="14" y2="15"/>
          </svg>
        </div>
        <h3>Crédito vs Investimentos</h3>
        <p>Vale tomar crédito ou consumir parte dos investimentos? Cronograma mês a mês com PDF.</p>
        <div class="calc-card-footer">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
          </svg>
        </div>
      </a>

      <a href="/calculadoras/cet.html" class="calc-card">
        <div class="calc-card-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 2v20"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>
          </svg>
        </div>
        <h3>CET — Custo Efetivo Total</h3>
        <p>Calcule a taxa de juros real cobrada num financiamento a partir do valor liberado e das parcelas.</p>
        <div class="calc-card-footer">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
          </svg>
        </div>
      </a>

      <a href="/calculadoras/avista-vs-prazo.html" class="calc-card">
        <div class="calc-card-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M20 12V8H6a2 2 0 0 1 0-4h12v4"/>
            <path d="M4 6v12a2 2 0 0 0 2 2h14v-4"/>
            <path d="M18 12a2 2 0 0 0 0 4h4v-4Z"/>
          </svg>
        </div>
        <h3>À Vista ou Parcelado?</h3>
        <p>Considerando o seu rendimento, vale mais o desconto à vista ou parcelar e investir a diferença?</p>
        <div class="calc-card-footer">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
          </svg>
        </div>
      </a>

      <a href="/calculadoras/amortizacao.html" class="calc-card">
        <div class="calc-card-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M3 3v18h18"/>
            <path d="M19 7l-6 6-3-3-5 5"/>
          </svg>
        </div>
        <h3>Amortização — SAC e Price</h3>
        <p>Monte a tabela de um financiamento com correção e seguro, simule aportes extras e compare reduzir prazo vs. reduzir parcela.</p>
        <div class="calc-card-footer">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
          </svg>
        </div>
      </a>

    </div>

    <div class="disclaimer">
      Material de uso interno · Não distribuir para clientes
    </div>

  </main>
</div>

<script is:inline src="/scripts/sidebar.js"></script>
<script is:inline src="/scripts/polish.js"></script>
<script is:inline src="/scripts/theme-toggle.js"></script>
<script is:inline src="/scripts/atb_footer_date.js"></script>
<script is:inline src="/scripts/atb_ticker.js"></script>
</body>
</html>
