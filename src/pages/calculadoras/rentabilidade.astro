---
import Layout from '../../layouts/Layout.astro';
import '../../styles/private-calc.css';
---
<Layout
  title="Rentabilidade · Calculadoras · Invest Analysis"
  footerCrumb="Calculadoras"
>
  <div slot="topbar-sub" class="atb-sub">
    <div class="atb-sub-pages">
      <a href="/calculadoras/troca-ativos.html" class="atb-sub-page">Troca de Ativos</a>
      <a href="/calculadoras/limite-fgc.html" class="atb-sub-page">Limite FGC</a>
      <a href="/calculadoras/alocacao-fgc.html" class="atb-sub-page">Alocação FGC</a>
      <a href="/calculadoras/rentabilidade.html" class="atb-sub-page is-active">Rentabilidade</a>
      <a href="/calculadoras/credito-vs-invest.html" class="atb-sub-page">Crédito vs. Investimentos</a>
      <a href="/calculadoras/cet.html" class="atb-sub-page">CET</a>
      <a href="/calculadoras/avista-vs-prazo.html" class="atb-sub-page">À Vista vs Parcelado</a>
      <a href="/calculadoras/amortizacao.html" class="atb-sub-page">Amortização</a>
    </div>
    <div class="atb-kpis" aria-live="polite"><div class="atb-kpi-group is-active" data-kpi="cdi"><span class="atb-kpi-group-label">CDI</span><div class="atb-kpi"><span class="atb-kpi-label" data-month>Mai</span><span class="atb-kpi-value">0,48%</span></div><div class="atb-kpi is-secondary"><span class="atb-kpi-label">Ano</span><span class="atb-kpi-value">5,04%</span></div><div class="atb-kpi is-tertiary"><span class="atb-kpi-label">12m</span><span class="atb-kpi-value">14,83%</span></div></div><div class="atb-kpi-group" data-kpi="ibov"><span class="atb-kpi-group-label">Ibov</span><div class="atb-kpi"><span class="atb-kpi-label" data-month>Mai</span><span class="atb-kpi-value neg">-4,78%</span></div><div class="atb-kpi is-secondary"><span class="atb-kpi-label">Ano</span><span class="atb-kpi-value pos">+10,70%</span></div><div class="atb-kpi is-tertiary"><span class="atb-kpi-label">12m</span><span class="atb-kpi-value pos">+28,86%</span></div></div></div>
  </div>


<section class="page-hero" data-private-hero>
  <p class="eyebrow">Calculadoras · Rentabilidade</p>
  <h1>Rentabilidade real. <span class="muted">Curva e mercado.</span></h1>
  <p>Quanto seu ativo rendeu de verdade, considerando IR e marcação a mercado, frente ao CDI e ao IPCA do mesmo período.</p>
</section>

<div class="ac-page">

  <div class="ac-toolbar">
    <nav class="ac-breadcrumb" aria-label="Navegação">
      <a href="/index.html">Início</a>
      <span class="ac-breadcrumb-sep">›</span>
      <span class="ac-breadcrumb-current">Calculadoras</span>
      <span class="ac-breadcrumb-sep">›</span>
      <span class="ac-breadcrumb-current">Rentabilidade</span>
    </nav>
    <button type="button" class="ac-clear-btn calc-clear-btn" title="Limpar todos os campos">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/></svg>
      Limpar tudo
    </button>
  </div>

  <!-- Badge fonte de dados -->
  <div style="display:flex;gap:8px;flex-wrap:wrap;margin-bottom:16px;justify-content:center">
    <span class="ac-bdg">Feriados ANBIMA 1999–2028</span>
    <span class="ac-bdg muted">CDI / IPCA · BACEN</span>
  </div>

  <!-- ── DADOS DO ATIVO ──────────────────────────────────────── -->
  <section class="ac-section">
    <div class="ac-section-head">
      <h2>Ativo. <span class="muted-sub">Identificação.</span></h2>
    </div>
    <div class="ac-grid-2">
      <div class="ac-field ac-field-text">
        <label>Nome do ativo</label>
        <input type="text" id="r3-ativo" placeholder="Ex.: CDB Banco XYZ">
      </div>
      <div style="display:flex;align-items:center;justify-content:center">
        <label class="ac-check">
          <input type="checkbox" id="r3-isento">
          <span class="box"><svg viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><polyline points="2 6 5 9 10 3"/></svg></span>
          Isento de IR (LCI, LCA, CRI, CRA…)
        </label>
      </div>
    </div>
  </section>

  <!-- ── DATAS E VALORES ─────────────────────────────────────── -->
  <section class="ac-section">
    <div class="ac-section-head">
      <h2>Datas e valores. <span class="muted-sub">Aplicação, vencimento e cotação.</span></h2>
    </div>
    <div class="ac-grid-3">
      <div class="ac-field"><label>Data da aplicação</label><input type="date" id="r3-dt-aplic"></div>
      <div class="ac-field"><label>Data de vencimento</label><input type="date" id="r3-dt-venc"></div>
      <div class="ac-field"><label>Data da cotação</label><input type="date" id="r3-dt-cotac"></div>
    </div>
    <div class="ac-grid-3" style="margin-top:6px">
      <div class="ac-field">
        <label>Valor aplicado <span class="unit">R$</span></label>
        <input type="text" inputmode="decimal" id="r3-v-aplic" placeholder="0,00">
      </div>
      <div class="ac-field">
        <label>Valor bruto de curva <span class="unit">R$</span></label>
        <input type="text" inputmode="decimal" id="r3-v-curva" placeholder="0,00">
      </div>
      <div class="ac-field">
        <label>Valor bruto de venda <span class="unit">R$</span></label>
        <input type="text" inputmode="decimal" id="r3-v-venda" placeholder="0,00">
      </div>
    </div>
  </section>

  <!-- ── MÉTRICAS DO PERÍODO ─────────────────────────────────── -->
  <section class="ac-section">
    <div class="ac-section-head">
      <h2>Período. <span class="muted-sub">Indicadores até a data da cotação.</span></h2>
    </div>
    <div class="ac-grid-4 ac-grid-divided">
      <div class="ac-metric">
        <span class="lbl">Dias corridos</span>
        <span class="val sm" id="r3-dc">—</span>
      </div>
      <div class="ac-metric">
        <span class="lbl">Dias úteis</span>
        <span class="val sm" id="r3-du">—</span>
      </div>
      <div class="ac-metric">
        <span class="lbl">Alíquota IR</span>
        <span class="val sm" id="r3-ir" style="color:#B8590E">—</span>
      </div>
      <div class="ac-metric">
        <span class="lbl">CDI do período</span>
        <span class="val sm pos" id="r3-cdi-p">—</span>
      </div>
    </div>
    <div class="ac-grid-2 ac-grid-divided" style="margin-top:14px;border-top:0.5px solid var(--private-divider);padding-top:14px">
      <div class="ac-metric">
        <span class="lbl">IPCA do período</span>
        <span class="val sm pos" id="r3-ipca-p">—</span>
      </div>
      <div class="ac-metric">
        <span class="lbl">Dados atualizados em</span>
        <span class="val sm" style="font-size:14px;color:var(--private-muted)">14/05/2026</span>
      </div>
    </div>
  </section>

  <!-- ── BLOCO CURVA ─────────────────────────────────────────── -->
  <section class="ac-section">
    <div class="ac-section-head">
      <h2>Curva. <span class="muted-sub">Valor teórico contratado.</span></h2>
    </div>
    <div class="ac-tbl-wrap">
      <table class="ac-tbl">
        <thead>
          <tr><th>Métrica</th><th>Bruto</th><th>Líquido</th></tr>
        </thead>
        <tbody>
          <tr><td>Valor atual</td><td class="blu" id="r3-c-vbr">—</td><td class="pos" id="r3-c-vlq">—</td></tr>
          <tr><td>Rentabilidade total</td><td id="r3-c-rtbr">—</td><td id="r3-c-rtlq">—</td></tr>
          <tr><td>Rentabilidade anual</td><td id="r3-c-rabr">—</td><td id="r3-c-ralq">—</td></tr>
          <tr><td>% CDI</td><td id="r3-c-cdibr">—</td><td id="r3-c-cdilq">—</td></tr>
          <tr><td>IPCA+</td><td id="r3-c-ipcabr">—</td><td id="r3-c-ipcalq">—</td></tr>
        </tbody>
      </table>
    </div>
  </section>

  <!-- ── BLOCO VENDA ─────────────────────────────────────────── -->
  <section class="ac-section">
    <div class="ac-section-head">
      <h2>Venda. <span class="muted-sub">Marcação a mercado.</span></h2>
    </div>
    <div class="ac-tbl-wrap">
      <table class="ac-tbl">
        <thead>
          <tr><th>Métrica</th><th>Bruto</th><th>Líquido</th></tr>
        </thead>
        <tbody>
          <tr><td>Valor atual</td><td class="blu" id="r3-v-vbr">—</td><td class="pos" id="r3-v-vlq">—</td></tr>
          <tr><td>Rentabilidade total</td><td id="r3-v-rtbr">—</td><td id="r3-v-rtlq">—</td></tr>
          <tr><td>Rentabilidade anual</td><td id="r3-v-rabr">—</td><td id="r3-v-ralq">—</td></tr>
          <tr><td>% CDI</td><td id="r3-v-cdibr">—</td><td id="r3-v-cdilq">—</td></tr>
          <tr><td>IPCA+</td><td id="r3-v-ipcabr">—</td><td id="r3-v-ipcalq">—</td></tr>
        </tbody>
      </table>
    </div>

    <!-- Disclaimers (visibilidade controlada pelo calc-rent.js) -->
    <div id="r3-disc-ir" class="ac-disc warn" style="display:none"></div>
    <div id="r3-disc-res" class="ac-disc ok" style="display:none"></div>
    <div id="r3-disc-ag" class="ac-disc info" style="display:none"></div>
    <div class="ac-data-tag" id="r3-data-tag"></div>

  </section>

</div>

<div class="ac-pdf-bar" id="r3-pdf-bar">
  <div class="left">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
      <polyline points="14 2 14 8 20 8"/>
      <line x1="12" y1="18" x2="12" y2="12"/>
      <polyline points="9 15 12 12 15 15"/>
    </svg>
    <span class="title">Salvar simulação em PDF</span>
  </div>
  <button type="button" class="ac-pdf-btn" id="r3-pdf-btn">Gerar PDF</button>
</div>

  <Fragment slot="scripts">
    <script is:inline src="/scripts/data/feriados_anbima.js"></script>
    <script is:inline src="/scripts/data/cdi_diario.js"></script>
    <script is:inline src="/scripts/data/ipca_mensal.js"></script>
    <script is:inline src="/scripts/utils.js"></script>
    <script is:inline src="/scripts/calc-common.js"></script>
    <script is:inline src="/scripts/calc-rent.js"></script>
    <!-- Formatação condicional pos/neg nas linhas das tabelas (curva/venda) -->
    <script is:inline>
(function () {
  // % CDI:        >= 100  = verde (bate o CDI), < 100 = vermelho
  // IPCA+ / Rent: >  0    = verde,              < 0   = vermelho
  var SIGN_BASED = ['r3-c-rtbr','r3-c-rtlq','r3-c-rabr','r3-c-ralq',
                    'r3-c-ipcabr','r3-c-ipcalq',
                    'r3-v-rtbr','r3-v-rtlq','r3-v-rabr','r3-v-ralq',
                    'r3-v-ipcabr','r3-v-ipcalq'];
  var CDI_BASED  = ['r3-c-cdibr','r3-c-cdilq','r3-v-cdibr','r3-v-cdilq'];

  function parseBR(s) {
    if (!s) return null;
    s = String(s).trim();
    if (s === '—' || s === '-') return null;
    // pt-BR: "1.234,56%" -> "1234.56"
    var m = s.replace(/[^\d,.\-+]/g, '').replace(/\./g, '').replace(',', '.');
    var n = parseFloat(m);
    return isNaN(n) ? null : n;
  }
  function paintOne(id, mode) {
    var el = document.getElementById(id);
    if (!el) return;
    var n = parseBR(el.textContent);
    el.classList.remove('pos','neg');
    if (n == null) return;
    if (mode === 'cdi') {
      if (n >= 100) el.classList.add('pos');
      else if (n < 100) el.classList.add('neg');
    } else {
      if (n > 0) el.classList.add('pos');
      else if (n < 0) el.classList.add('neg');
    }
  }
  function paint() {
    SIGN_BASED.forEach(function (id) { paintOne(id, 'sign'); });
    CDI_BASED.forEach(function (id)  { paintOne(id, 'cdi');  });
  }

  document.addEventListener('input',  function () { setTimeout(paint, 60); });
  document.addEventListener('change', function () { setTimeout(paint, 60); });
  if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', paint);
  else paint();
})();
    </script>
  </Fragment>
</Layout>
