---
// index — HOME real (grid de cards). Usa o Layout (topbar mega-menu).
// home_counts.js (module) preenche as contagens via fetch de dados.
import Layout from '../layouts/Layout.astro';
---
<Layout title="Invest Analysis">
  <style is:global>
    .home-wrap { max-width: 1080px; margin: 0 auto 72px; padding: 0 22px; }
    @media (max-width: 833px) { .home-wrap { padding: 0 16px; margin-bottom: 48px; } }
    .home-sec-label { font-size: 12px; font-weight: 600; letter-spacing: .05em; text-transform: uppercase;
      color: var(--private-muted); margin: 30px 0 12px; display: flex; align-items: center; gap: 12px; }
    .home-sec-label::after { content: ""; flex: 1; height: 1px; background: var(--private-divider, rgba(0,0,0,.08)); }
    .home-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(212px, 1fr)); gap: 12px; }
    @media (max-width: 600px) { .home-grid { grid-template-columns: repeat(auto-fill, minmax(150px, 1fr)); } }
    .home-card { display: flex; flex-direction: column; gap: 9px; background: #fff;
      border: 0.5px solid var(--private-border, #e6e6e6); border-radius: 16px; padding: 16px 16px 15px;
      text-decoration: none; color: inherit; min-height: 118px; box-shadow: 0 1px 2px rgba(0,0,0,.04);
      transition: transform .25s cubic-bezier(.4,0,.2,1), box-shadow .25s, border-color .25s; }
    .home-card:hover { transform: translateY(-2px); box-shadow: 0 6px 18px rgba(0,0,0,.07); }
    .home-ic { width: 38px; height: 38px; border-radius: 11px; display: flex; align-items: center; justify-content: center; flex: none; }
    .home-ic svg { width: 20px; height: 20px; fill: none; stroke: currentColor; stroke-width: 1.8; stroke-linecap: round; stroke-linejoin: round; }
    .home-card h3 { font-size: 15.5px; font-weight: 600; margin: 0; letter-spacing: -.01em; line-height: 1.15; }
    .home-card p { font-size: 12.5px; color: var(--private-muted); line-height: 1.4; margin: 0; flex: 1; }
    .home-card-foot { font-size: 11.5px; color: var(--private-muted); font-variant-numeric: tabular-nums; }
    .sec-inv  .home-ic { background: rgba(42,138,240,.12); color: #2a8af0; }
    .sec-calc .home-ic { background: rgba(37,165,95,.14);  color: #1f9d57; }
    .sec-plan .home-ic { background: rgba(214,138,26,.15); color: #c77d12; }
    .sec-port .home-ic { background: rgba(142,142,147,.16); color: #8e8e93; }
    .home-card-row { flex-direction: row; align-items: center; gap: 16px; min-height: 0; }
    .home-card-row .home-row-txt { flex: 1; display: flex; flex-direction: column; gap: 3px; }
    .home-card-row p { flex: none; }
    .home-row-arrow svg { width: 20px; height: 20px; fill: none; stroke: var(--private-muted); stroke-width: 2; stroke-linecap: round; stroke-linejoin: round; }
  </style>

  <section class="private-hero" data-private-hero>
    <p class="eyebrow">Inteligência de investimentos</p>
    <h1>Análises e ferramentas em um só lugar.</h1>
    <p class="hero-sub">Analise dados, simule cenários e construa seu legado com inteligência.</p>
  </section>
  <div class="home-wrap">

    <p class="home-sec-label">Investimentos</p>
    <div class="home-grid sec-inv">
      <a href="/fundos.html" class="home-card">
        <span class="home-ic"><svg viewBox="0 0 24 24"><path d="M3 21h18"/><path d="M7 21v-6"/><path d="M12 21V8"/><path d="M17 21v-10"/></svg></span>
        <h3>Fundos</h3>
        <p>Rentabilidade, captação e demais detalhes dos fundos CVM 175.</p>
        <div class="home-card-foot"><span class="count">1.754 fundos</span></div>
      </a>
      <a href="/previdencia.html" class="home-card">
        <span class="home-ic"><svg viewBox="0 0 24 24"><path d="M12 3l8 3v5c0 5-3.5 8-8 10-4.5-2-8-5-8-10V6z"/></svg></span>
        <h3>Previdência</h3>
        <p>Catálogo completo das principais instituições.</p>
        <div class="home-card-foot"><span class="count">705 fundos</span></div>
      </a>
      <a href="/comparacao.html" class="home-card">
        <span class="home-ic"><svg viewBox="0 0 24 24"><path d="M4 5v14h16"/><path d="M8 14l3-3 3 2 4-6"/></svg></span>
        <h3>Comparação de fundos</h3>
        <p>Retorno histórico e correlação.</p>
        <div class="home-card-foot"><span class="count">2.459 ativos</span></div>
      </a>
      <a href="/etfs.html" class="home-card">
        <span class="home-ic"><svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="9"/><path d="M3 12h18"/><path d="M12 3c2.6 2.5 2.6 15.5 0 18"/><path d="M12 3c-2.6 2.5-2.6 15.5 0 18"/></svg></span>
        <h3>ETFs USA</h3>
        <p>ETFs do mercado americano por classe e tema.</p>
        <div class="home-card-foot"><span class="count">4.606 ETFs</span></div>
      </a>
    </div>

    <p class="home-sec-label">Calculadoras</p>
    <div class="home-grid sec-calc">
      <a href="/calculadoras/troca-ativos.html" class="home-card">
        <span class="home-ic"><svg viewBox="0 0 24 24"><path d="M4 8h13l-3-3"/><path d="M20 16H7l3 3"/></svg></span>
        <h3>Troca de ativos</h3>
        <p>Vale a pena trocar?</p>
      </a>
      <a href="/calculadoras/limite-fgc.html" class="home-card">
        <span class="home-ic"><svg viewBox="0 0 24 24"><path d="M12 3v2"/><path d="M3.5 12a8.5 8.5 0 0 1 17 0z"/><path d="M12 12v6a2.5 2.5 0 0 0 4.5 1.5"/></svg></span>
        <h3>FGC</h3>
        <p>Quanto investir hoje para ficar coberto até o vencimento?</p>
      </a>
      <a href="/calculadoras/rentabilidade.html" class="home-card">
        <span class="home-ic"><svg viewBox="0 0 24 24"><path d="M3 17l6-6 4 4 8-8"/><path d="M15 7h6v6"/></svg></span>
        <h3>Rentabilidade</h3>
        <p>Quanto rendeu em relação aos principais indexadores?</p>
      </a>
      <a href="/calculadoras/credito-vs-invest.html" class="home-card">
        <span class="home-ic"><svg viewBox="0 0 24 24"><path d="M12 3v18"/><path d="M5 7h14"/><path d="M5 7l-3 6h6z"/><path d="M19 7l-3 6h6z"/><path d="M8 21h8"/></svg></span>
        <h3>Crédito vs. investimentos</h3>
        <p>Vale a pena resgatar ou me alavancar?</p>
      </a>
      <a href="/calculadoras/cet.html" class="home-card">
        <span class="home-ic"><svg viewBox="0 0 24 24"><path d="M19 5L5 19"/><circle cx="7" cy="7" r="2.5"/><circle cx="17" cy="17" r="2.5"/></svg></span>
        <h3>CET</h3>
        <p>Aquela taxa zero é zero mesmo?</p>
      </a>
      <a href="/calculadoras/avista-vs-prazo.html" class="home-card">
        <span class="home-ic"><svg viewBox="0 0 24 24"><rect x="2" y="5" width="20" height="14" rx="2.5"/><path d="M2 10h20"/></svg></span>
        <h3>À vista × parcelado</h3>
        <p>Vou parcelar e investir ou pagar à vista?</p>
      </a>
    </div>

    <p class="home-sec-label">Planejamento financeiro</p>
    <div class="home-grid sec-plan">
      <a href="/calculadoras/aposentadoria.html" class="home-card">
        <span class="home-ic"><svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4 12H2M22 12h-2M5.6 5.6l1.4 1.4M17 17l1.4 1.4M18.4 5.6L17 7M7 17l-1.4 1.4"/></svg></span>
        <h3>Aposentadoria</h3>
        <p>Quanto precisa juntar para se aposentar.</p>
      </a>
      <a href="/calculadoras/valor-futuro.html" class="home-card">
        <span class="home-ic"><svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="9"/><circle cx="12" cy="12" r="5"/><circle cx="12" cy="12" r="1.6"/></svg></span>
        <h3>Valor futuro</h3>
        <p>Com o que já tenho e os aportes, quanto terei no futuro?</p>
      </a>
      <a href="/calculadoras/come-cotas.html" class="home-card">
        <span class="home-ic"><svg viewBox="0 0 24 24"><circle cx="6" cy="6" r="2.5"/><circle cx="6" cy="18" r="2.5"/><path d="M8 7.5L20 16"/><path d="M8 16.5L20 8"/></svg></span>
        <h3>Come-cotas</h3>
        <p>Quanto de imposto fica para o Leão no longo prazo?</p>
      </a>
      <a href="/calculadoras/simular-pgbl.html" class="home-card">
        <span class="home-ic"><svg viewBox="0 0 24 24"><rect x="5" y="3" width="14" height="18" rx="2.5"/><path d="M9 8h6M9 12h6"/><path d="M9 16l1.4 1.4L13.5 14.5"/></svg></span>
        <h3>PGBL</h3>
        <p>Qual o meu benefício fiscal?</p>
      </a>
      <a href="/calculadoras/irpfm.html" class="home-card">
        <span class="home-ic"><svg viewBox="0 0 24 24"><rect x="5" y="3" width="14" height="18" rx="2.5"/><path d="M9 7h6"/><path d="M12 11v6"/><path d="M13.8 12.2a2 2 0 0 0-3.3 1.5c0 2.4 3.3 1 3.3 3a2 2 0 0 1-3.3 1.5"/></svg></span>
        <h3>IRPF-m</h3>
        <p>Simulador de imposto adicional a pagar.</p>
      </a>
      <a href="/calculadoras/sucessao-previdencia.html" class="home-card">
        <span class="home-ic"><svg viewBox="0 0 24 24"><path d="M12 2.5l7 3v5.5c0 4.4-3 7.8-7 9.5-4-1.7-7-5.1-7-9.5V5.5z"/><path d="M9.2 12l2 2 3.6-3.8"/></svg></span>
        <h3>Sucessão na previdência</h3>
        <p>Vale a pena pagar IOF no VGBL pensando em sucessão?</p>
      </a>
    </div>


  </div>

  <Fragment slot="scripts">
    <script type="module" is:inline src="/js/home_counts.js"></script>
  </Fragment>
</Layout>
